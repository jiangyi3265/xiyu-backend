# WeChat Mini Program
WX_APPID=wxc0bf4aba46ccdfe9
WX_SECRET=replace-with-mini-program-secret

# WeChat Pay APIv3
# MCH ID is the pure numeric merchant id from WeChat Pay merchant platform.
WX_MCH_ID=replace-with-numeric-mchid
WX_PAY_MERCHANT_SERIAL_NO=replace-with-apiclient-cert-serial-no
WX_PAY_PRIVATE_KEY_PATH=/opt/xiyu/backend/certs/apiclient_key.pem
WX_PAY_API_V3_KEY=replace-with-32-char-api-v3-key
WX_NOTIFY_URL=https://xiyu.oksja.cn/app/pay/notify

# Choose one verifier mode:
# 1) WeChat Pay platform certificate
WX_PAY_PLATFORM_CERT_PATH=/opt/xiyu/backend/certs/wechatpay_platform_cert.pem

# 2) Or WeChat Pay public key mode
# WX_PAY_PLATFORM_PUBLIC_KEY_PATH=/opt/xiyu/backend/certs/wechatpay_public_key.pem
# WX_PAY_PLATFORM_PUBLIC_KEY_ID=replace-with-pub_key_id
