<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hotel.mapper.LwfBannerMapper">

    <resultMap type="LwfBanner" id="LwfBannerResult">
        <result property="bannerId"    column="banner_id"    />
        <result property="title"       column="title"        />
        <result property="sub"         column="sub"          />
        <result property="scene"       column="scene"        />
        <result property="sort"        column="sort"         />
        <result property="status"      column="status"       />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"  column="create_time"  />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"  column="update_time"  />
        <result property="remark"      column="remark"       />
    </resultMap>

    <sql id="selectLwfBannerVo">
        select banner_id, title, sub, scene, sort, status, create_by, create_time, update_by, update_time, remark from lwf_banner
    </sql>

    <select id="selectLwfBannerList" parameterType="LwfBanner" resultMap="LwfBannerResult">
        <include refid="selectLwfBannerVo"/>
        <where>
            <if test="title != null and title != ''"> and title like concat('%', #{title}, '%')</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by sort asc, banner_id asc
    </select>

    <select id="selectLwfBannerByBannerId" parameterType="Long" resultMap="LwfBannerResult">
        <include refid="selectLwfBannerVo"/>
        where banner_id = #{bannerId}
    </select>

    <insert id="insertLwfBanner" parameterType="LwfBanner" useGeneratedKeys="true" keyProperty="bannerId">
        insert into lwf_banner
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="sub != null">sub,</if>
            <if test="scene != null">scene,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="sub != null">#{sub},</if>
            <if test="scene != null">#{scene},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateLwfBanner" parameterType="LwfBanner">
        update lwf_banner
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="sub != null">sub = #{sub},</if>
            <if test="scene != null">scene = #{scene},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where banner_id = #{bannerId}
    </update>

    <delete id="deleteLwfBannerByBannerId" parameterType="Long">
        delete from lwf_banner where banner_id = #{bannerId}
    </delete>

    <delete id="deleteLwfBannerByBannerIds" parameterType="String">
        delete from lwf_banner where banner_id in
        <foreach item="bannerId" collection="array" open="(" separator="," close=")">
            #{bannerId}
        </foreach>
    </delete>
</mapper>
