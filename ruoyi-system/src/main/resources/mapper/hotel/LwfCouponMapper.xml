<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hotel.mapper.LwfCouponMapper">

    <resultMap type="LwfCoupon" id="LwfCouponResult">
        <result property="couponId"    column="coupon_id"    />
        <result property="title"       column="title"        />
        <result property="cat"         column="cat"          />
        <result property="amount"      column="amount"       />
        <result property="condAmount"  column="cond_amount"  />
        <result property="descr"       column="descr"        />
        <result property="validTime"   column="valid_time"   />
        <result property="totalQty"    column="total_qty"    />
        <result property="status"      column="status"       />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"  column="create_time"  />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"  column="update_time"  />
        <result property="remark"      column="remark"       />
    </resultMap>

    <sql id="selectLwfCouponVo">
        select coupon_id, title, cat, amount, cond_amount, descr, valid_time, total_qty, status, create_by, create_time, update_by, update_time, remark from lwf_coupon
    </sql>

    <select id="selectLwfCouponList" parameterType="LwfCoupon" resultMap="LwfCouponResult">
        <include refid="selectLwfCouponVo"/>
        <where>
            <if test="title != null and title != ''"> and title like concat('%', #{title}, '%')</if>
            <if test="cat != null"> and cat = #{cat}</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by coupon_id desc
    </select>

    <select id="selectLwfCouponByCouponId" parameterType="Long" resultMap="LwfCouponResult">
        <include refid="selectLwfCouponVo"/>
        where coupon_id = #{couponId}
    </select>

    <insert id="insertLwfCoupon" parameterType="LwfCoupon" useGeneratedKeys="true" keyProperty="couponId">
        insert into lwf_coupon
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="cat != null">cat,</if>
            <if test="amount != null">amount,</if>
            <if test="condAmount != null">cond_amount,</if>
            <if test="descr != null">descr,</if>
            <if test="validTime != null">valid_time,</if>
            <if test="totalQty != null">total_qty,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="cat != null">#{cat},</if>
            <if test="amount != null">#{amount},</if>
            <if test="condAmount != null">#{condAmount},</if>
            <if test="descr != null">#{descr},</if>
            <if test="validTime != null">#{validTime},</if>
            <if test="totalQty != null">#{totalQty},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateLwfCoupon" parameterType="LwfCoupon">
        update lwf_coupon
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="cat != null">cat = #{cat},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="condAmount != null">cond_amount = #{condAmount},</if>
            <if test="descr != null">descr = #{descr},</if>
            <if test="validTime != null">valid_time = #{validTime},</if>
            <if test="totalQty != null">total_qty = #{totalQty},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where coupon_id = #{couponId}
    </update>

    <delete id="deleteLwfCouponByCouponId" parameterType="Long">
        delete from lwf_coupon where coupon_id = #{couponId}
    </delete>

    <delete id="deleteLwfCouponByCouponIds" parameterType="String">
        delete from lwf_coupon where coupon_id in
        <foreach item="couponId" collection="array" open="(" separator="," close=")">
            #{couponId}
        </foreach>
    </delete>
</mapper>
