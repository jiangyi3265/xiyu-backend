<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hotel.mapper.LwfProductMapper">

    <resultMap type="LwfProduct" id="LwfProductResult">
        <result property="productId"   column="product_id"   />
        <result property="type"        column="type"         />
        <result property="title"       column="title"        />
        <result property="main"        column="main"         />
        <result property="sub"         column="sub"          />
        <result property="theme"       column="theme"        />
        <result property="badge"       column="badge"        />
        <result property="scene"       column="scene"        />
        <result property="price"       column="price"        />
        <result property="oldPrice"    column="old_price"    />
        <result property="people"      column="people"       />
        <result property="terms"       column="terms"        />
        <result property="items"       column="items"        />
        <result property="sort"        column="sort"         />
        <result property="status"      column="status"       />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"  column="create_time"  />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"  column="update_time"  />
        <result property="remark"      column="remark"       />
    </resultMap>

    <sql id="selectLwfProductVo">
        select product_id, type, title, main, sub, theme, badge, scene, price, old_price, people, terms, items, sort, status, create_by, create_time, update_by, update_time, remark from lwf_product
    </sql>

    <select id="selectLwfProductList" parameterType="LwfProduct" resultMap="LwfProductResult">
        <include refid="selectLwfProductVo"/>
        <where>
            <if test="title != null and title != ''"> and title like concat('%', #{title}, '%')</if>
            <if test="type != null and type != ''"> and type = #{type}</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by sort asc, product_id asc
    </select>

    <select id="selectLwfProductByProductId" parameterType="Long" resultMap="LwfProductResult">
        <include refid="selectLwfProductVo"/>
        where product_id = #{productId}
    </select>

    <insert id="insertLwfProduct" parameterType="LwfProduct" useGeneratedKeys="true" keyProperty="productId">
        insert into lwf_product
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="type != null">type,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="main != null">main,</if>
            <if test="sub != null">sub,</if>
            <if test="theme != null">theme,</if>
            <if test="badge != null">badge,</if>
            <if test="scene != null">scene,</if>
            <if test="price != null">price,</if>
            <if test="oldPrice != null">old_price,</if>
            <if test="people != null">people,</if>
            <if test="terms != null">terms,</if>
            <if test="items != null">items,</if>
            <if test="sort != null">sort,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="type != null">#{type},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="main != null">#{main},</if>
            <if test="sub != null">#{sub},</if>
            <if test="theme != null">#{theme},</if>
            <if test="badge != null">#{badge},</if>
            <if test="scene != null">#{scene},</if>
            <if test="price != null">#{price},</if>
            <if test="oldPrice != null">#{oldPrice},</if>
            <if test="people != null">#{people},</if>
            <if test="terms != null">#{terms},</if>
            <if test="items != null">#{items},</if>
            <if test="sort != null">#{sort},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateLwfProduct" parameterType="LwfProduct">
        update lwf_product
        <trim prefix="SET" suffixOverrides=",">
            <if test="type != null">type = #{type},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="main != null">main = #{main},</if>
            <if test="sub != null">sub = #{sub},</if>
            <if test="theme != null">theme = #{theme},</if>
            <if test="badge != null">badge = #{badge},</if>
            <if test="scene != null">scene = #{scene},</if>
            <if test="price != null">price = #{price},</if>
            <if test="oldPrice != null">old_price = #{oldPrice},</if>
            <if test="people != null">people = #{people},</if>
            <if test="terms != null">terms = #{terms},</if>
            <if test="items != null">items = #{items},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where product_id = #{productId}
    </update>

    <delete id="deleteLwfProductByProductId" parameterType="Long">
        delete from lwf_product where product_id = #{productId}
    </delete>

    <delete id="deleteLwfProductByProductIds" parameterType="String">
        delete from lwf_product where product_id in
        <foreach item="productId" collection="array" open="(" separator="," close=")">
            #{productId}
        </foreach>
    </delete>
</mapper>
